            "index": 0
          }
        ]
      ]
    },
    "Sanitizar ocorrência": {
      "main": [
        [
          {
            "node": "Enviar alerta SMTP",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Enviar alerta SMTP": {
      "main": [
        [
          {
            "node": "Registrar alerta no ledger",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
