    {
      "id": "criar-post-de-carrossel-facebook",
      "name": "Criar post de carrossel Facebook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/{{ $json.metaApiVersion || \"v23.0\" }}/{{ $json.metaPageId }}/feed",
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth2Api",
        "sendHeaders": true,
        "headerParameters": {
